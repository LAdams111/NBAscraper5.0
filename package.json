{
  "name": "scraper-nba",
  "version": "1.0.0",
  "description": "NBA player-season scraper for Hoop Central via balldontlie API",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "scrape": "node dist/index.js",
    "scrape:dev": "tsx src/index.ts",
    "scrape:dry-run": "node dist/index.js --dry-run"
  },
  "dependencies": {
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
